# Blender 5.0.1 MTL File: 'star.blend'
# www.blender.org

newmtl Star
Ka 1.000000 1.000000 1.000000
Ks 0.500000 0.500000 0.500000
Ke 0.000000 0.000000 0.000000
Ni 1.500000
d 1.000000
illum 2
map_Kd ../textures/gold star_Star_BaseColor.png
map_Ns ../textures/gold star_Star_Roughness.png
map_refl ../textures/gold star_Star_Metallic.png
map_Bump -bm 1.000000 ../textures/gold star_Star_Normal.png
